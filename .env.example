# ═══════════════════════════════════════════════
# 🦀 Pincer — Environment Variables
# ═══════════════════════════════════════════════
# Copy to .env and fill in your values:
#   cp .env.example .env

# ── LLM Provider ─────────────────────────────
PINCER_DEFAULT_PROVIDER=anthropic       # anthropic | openai
PINCER_ANTHROPIC_API_KEY=sk-ant-...     # Required for Anthropic
PINCER_OPENAI_API_KEY=sk-proj-...       # Required for OpenAI + voice transcription
PINCER_DEFAULT_MODEL=claude-sonnet-4-5-20250929
PINCER_MAX_TOKENS=4096
PINCER_TEMPERATURE=0.7

# ── Telegram ─────────────────────────────────
PINCER_TELEGRAM_BOT_TOKEN=              # From @BotFather
PINCER_TELEGRAM_ALLOWED_USERS=          # Comma-separated user IDs (empty = allow all)

# ── Agent ────────────────────────────────────
PINCER_AGENT_NAME=Pincer
PINCER_MAX_TOOL_ITERATIONS=10
PINCER_MAX_SESSION_MESSAGES=50
PINCER_DAILY_BUDGET_USD=5.0

# ── Search ───────────────────────────────────
PINCER_TAVILY_API_KEY=tvly-...          # Optional: Tavily search

# ── Shell ────────────────────────────────────
PINCER_SHELL_ENABLED=true
PINCER_SHELL_TIMEOUT=30
PINCER_SHELL_REQUIRE_APPROVAL=true

# ── Memory ───────────────────────────────────
PINCER_MEMORY_ENABLED=true
PINCER_SUMMARY_MODEL=claude-haiku-4-5-20251001
PINCER_SUMMARY_THRESHOLD=20

# ── Storage & Logging ────────────────────────
# PINCER_DATA_DIR=~/.pincer             # Default
PINCER_LOG_LEVEL=INFO

# ═══════════════════════════════════════════════
# Sprint 3: WhatsApp + Proactive Agent
# ═══════════════════════════════════════════════

# ── WhatsApp ─────────────────────────────────
PINCER_WHATSAPP_ENABLED=false
PINCER_WHATSAPP_SELF_CHAT_ONLY=true     # true = only self-chat + group mentions; false = allow DMs from allowlist
PINCER_WHATSAPP_DM_ALLOWLIST=           # Comma-separated; empty = self-chat and group mentions only
PINCER_WHATSAPP_GROUP_TRIGGER=pincer

# ── Cross-Channel Identity ───────────────────
# Format: telegram:TELEGRAM_USER_ID=whatsapp:PHONE_WITHOUT_PLUS
PINCER_IDENTITY_MAP=
PINCER_DEFAULT_USER_ID=

# ── Email (Gmail: use App Password) ──────────
PINCER_EMAIL_IMAP_HOST=imap.gmail.com
PINCER_EMAIL_IMAP_PORT=993
PINCER_EMAIL_SMTP_HOST=smtp.gmail.com
PINCER_EMAIL_SMTP_PORT=587
PINCER_EMAIL_USERNAME=
PINCER_EMAIL_PASSWORD=
PINCER_EMAIL_FROM=

# ── Google Calendar ──────────────────────────
# 1. Create OAuth 2.0 Client ID in Google Cloud Console
# 2. Download JSON -> save as data/google_credentials.json
# 3. On first calendar_today() call, browser opens for consent
# 4. Token auto-saved to data/google_token.json

# ── Proactive Agent ──────────────────────────
PINCER_OPENWEATHERMAP_API_KEY=
PINCER_NEWSAPI_KEY=
PINCER_BRIEFING_TIME=07:00
PINCER_BRIEFING_TIMEZONE=Europe/Berlin
PINCER_TIMEZONE=Europe/Berlin

# ── Webhooks ─────────────────────────────────
PINCER_WEBHOOK_PORT=8765
PINCER_WEBHOOK_SECRET=

# ═══════════════════════════════════════════════
# Sprint 4: Discord + Skills
# ═══════════════════════════════════════════════

# ── Discord ──────────────────────────────────
PINCER_DISCORD_BOT_TOKEN=

# ── Skills ───────────────────────────────────
# User skills directory (default: ~/.pincer/skills/)
# PINCER_SKILLS_DIR=~/.pincer/skills

# ═══════════════════════════════════════════════
# Sprint 5: Security + API + Docker
# ═══════════════════════════════════════════════

# ── Dashboard / API ─────────────────────────
PINCER_DASHBOARD_TOKEN=                # Bearer token for API auth (generate: python -c "import secrets; print(secrets.token_hex(32))")
PINCER_DASHBOARD_HOST=127.0.0.1        # Bind host (127.0.0.1 = local only, 0.0.0.0 = network)
PINCER_DASHBOARD_PORT=8080             # API server port
# PINCER_DASHBOARD_DIST=/app/dashboard/dist  # Override dashboard path (Docker sets this automatically)

# ── Security ────────────────────────────────
PINCER_AUDIT_DISABLED=false            # Set true to disable audit logging
PINCER_RATE_MESSAGES_PER_MIN=30        # Per-user message rate limit
PINCER_RATE_TOOLS_PER_MIN=20           # Per-user tool call rate limit
PINCER_MAX_CONCURRENT_LLM=5            # Max concurrent LLM requests
# PINCER_DEBUG=false                   # Enable debug mode (exposes /api/docs)

# ═══════════════════════════════════════════════
# Sprint 7: Voice Calling
# ═══════════════════════════════════════════════

# ── ngrok (Docker) ───────────────────────────
# Only needed when using docker compose --profile ngrok up
NGROK_AUTHTOKEN=                 # From https://dashboard.ngrok.com/get-started/your-authtoken

# ── Twilio ───────────────────────────────────
PINCER_VOICE_ENABLED=false
PINCER_TWILIO_ACCOUNT_SID=             # Twilio Account SID (ACxxxxxxxx)
PINCER_TWILIO_AUTH_TOKEN=              # Twilio Auth Token
PINCER_TWILIO_PHONE_NUMBER=            # Twilio phone number (E.164: +1234567890)
PINCER_VOICE_WEBHOOK_BASE_URL=         # Public HTTPS URL for Twilio webhooks

# ── Voice Engine ─────────────────────────────
PINCER_VOICE_ENGINE=conversation_relay # conversation_relay (Phase 1) | media_streams (Phase 2)
PINCER_VOICE_LANGUAGE=en-US            # Primary STT language
PINCER_VOICE_MAX_CALL_DURATION=600     # Max call length in seconds
PINCER_VOICE_MAX_HOLD_TIME=300         # Max IVR hold time in seconds

# ── STT/TTS Providers (Phase 2: Media Streams) ──
PINCER_DEEPGRAM_API_KEY=               # Deepgram streaming STT key
PINCER_ELEVENLABS_API_KEY=             # ElevenLabs streaming TTS key
PINCER_ELEVENLABS_VOICE_ID=            # Optional: specific voice ID

# ── Outbound Calling ─────────────────────────
PINCER_VOICE_OUTBOUND_ENABLED=false    # Enable agent-initiated calls
PINCER_VOICE_OUTBOUND_MAX_DAILY=10     # Max outbound calls per day

# ── Safety & Compliance ──────────────────────
PINCER_VOICE_RECORDING_ENABLED=false   # Enable call recording
PINCER_VOICE_CONSENT_MODE=one_party    # one_party | two_party | none
PINCER_VOICE_ALLOWED_CALLERS=*         # Comma-separated E.164 numbers (* = all)

# ═══════════════════════════════════════════════
# Sprint 7.5: Signal Messenger
# ═══════════════════════════════════════════════

# ── Signal ───────────────────────────────────
PINCER_SIGNAL_ENABLED=false
# SIGNAL_API_IMAGE=bbernhard/signal-cli-rest-api:latest-dev   # Docker image (default: latest-dev)
PINCER_SIGNAL_API_URL=http://signal-api:8080     # signal-cli-rest-api (inter-container)
PINCER_SIGNAL_PAIR_URL=http://127.0.0.1:8081     # URL for pincer signal pair (host-facing)
PINCER_SIGNAL_PHONE_NUMBER=                      # Registered phone (E.164: +1234567890)
PINCER_SIGNAL_ALLOWLIST=                         # Comma-separated allowed DM numbers; empty = allow all
PINCER_SIGNAL_GROUP_REPLY=mention_only           # mention_only | all | disabled
PINCER_SIGNAL_RECEIVE_MODE=websocket             # websocket | poll
PINCER_SIGNAL_POLL_INTERVAL=2                    # Poll interval in seconds (poll mode only)
# Cross-channel identity: signal:+491234567890
# PINCER_IDENTITY_MAP=telegram:12345=signal:+491234567890
