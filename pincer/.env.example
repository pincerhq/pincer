# ═══════════════════════════════════════════════
# 🦀 Pincer — Environment Variables
# ═══════════════════════════════════════════════
# Copy to .env and fill in your values:
#   cp .env.example .env

# ── LLM Provider ─────────────────────────────
PINCER_DEFAULT_PROVIDER=anthropic       # anthropic | openai
PINCER_ANTHROPIC_API_KEY=sk-ant-...     # Required for Anthropic
PINCER_OPENAI_API_KEY=sk-proj-...       # Required for OpenAI + voice transcription
PINCER_DEFAULT_MODEL=claude-sonnet-4-5-20250929
PINCER_MAX_TOKENS=4096
PINCER_TEMPERATURE=0.7

# ── Telegram ─────────────────────────────────
PINCER_TELEGRAM_BOT_TOKEN=              # From @BotFather
PINCER_TELEGRAM_ALLOWED_USERS=          # Comma-separated user IDs (empty = allow all)

# ── Agent ────────────────────────────────────
PINCER_AGENT_NAME=Pincer
PINCER_MAX_TOOL_ITERATIONS=10
PINCER_MAX_SESSION_MESSAGES=50
PINCER_DAILY_BUDGET_USD=5.0

# ── Search ───────────────────────────────────
PINCER_TAVILY_API_KEY=tvly-...          # Optional: Tavily search

# ── Shell ────────────────────────────────────
PINCER_SHELL_ENABLED=true
PINCER_SHELL_TIMEOUT=30
PINCER_SHELL_REQUIRE_APPROVAL=true

# ── Memory ───────────────────────────────────
PINCER_MEMORY_ENABLED=true
PINCER_SUMMARY_MODEL=claude-haiku-4-5-20251001
PINCER_SUMMARY_THRESHOLD=20

# ── Storage & Logging ────────────────────────
# PINCER_DATA_DIR=~/.pincer             # Default
PINCER_LOG_LEVEL=INFO
